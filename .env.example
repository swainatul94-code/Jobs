# Copy to .env and fill in. NEVER commit .env.
# Anthropic API key for AI features (fit ranking, tailored emails, JD insight).
ANTHROPIC_API_KEY=sk-ant-...

# STRONGLY recommended once deployed publicly: gate the cost-bearing endpoints
# so strangers who find the URL can't spend your API credits. The browser asks
# for it once and remembers it.
ACCESS_PASSWORD=

# Optional: Adzuna job source (AU + global, salary data). Free key at
# https://developer.adzuna.com . Source appears in the UI only when both are set.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional overrides:
# Global default model (cheapest sensible = Haiku):
# AI_MODEL=claude-haiku-4-5-20251001
#
# Per-task model routing for cost control. Each falls back to AI_MODEL if unset.
# Keep the cheap ones on Haiku; bump only what needs more quality (e.g. resume).
# AI_MODEL_RANK=claude-haiku-4-5-20251001
# AI_MODEL_INSIGHT=claude-haiku-4-5-20251001
# AI_MODEL_EMAIL=claude-haiku-4-5-20251001
# AI_MODEL_RESUME=claude-sonnet-4-6
#
# PORT=5500
# Default search used by the scheduled fetch (server/fetch-jobs.js):
# FETCH_QUERY=qa automation
# FETCH_LOCATION=
